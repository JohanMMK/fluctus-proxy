  "AIEG_distributie": "https://www.cwape.be/sites/default/files/cwape-documents/AIEG%20-%20Tarifs%20p%C3%A9riodiques%20de%20pr%C3%A9l%C3%A8vement%202026.pdf",
  "REW_distributie": "https://www.cwape.be/sites/default/files/cwape-documents/REW%20-%20Tarifs%20p%C3%A9riodiques%20de%20pr%C3%A9l%C3%A8vement%202026.pdf",
  "Wallonie_transport_alle_GRD": "https://media.ores.be/ores-cms/sjfflfhm/ed_transport_2026.pdf",
  "CWaPE_transport_uitleg": "https://www.cwape.be/node/179",
  "CWaPE_index_XLSX": "https://www.cwape.be/node/176",
